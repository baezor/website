---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { SITE_TITLE, SITE_URL } from "@/const";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";
import { userData } from "../../data";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const profilePhoto = userData[0].userPic;
const userName = userData[0].userName;

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Angel Baez",
    "alternateName": "baezor",
    "url": SITE_URL,
    "image": new URL("/favicon.png", SITE_URL).toString(),
    "email": "angel@romerobaez.com",
    "jobTitle": "Desarrollador Agéntico",
    "description": t('about.meta.description'),
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cancun",
      "addressRegion": "Quintana Roo",
      "addressCountry": "Mexico"
    },
    "sameAs": [
      "https://www.linkedin.com/in/angelromerobaez",
      "https://github.com/baezor",
      "https://x.com/baezor",
      "https://www.instagram.com/baez0r"
    ],
    "knowsAbout": [
      "Desarrollo Web",
      "TypeScript",
      "React",
      "Node.js",
      "Python",
      "Infraestructura Cloud",
      "Arquitectura de Software"
    ],
    "knowsLanguage": [
      { "@type": "Language", "name": "English" },
      { "@type": "Language", "name": "Spanish" }
    ]
  },
  "dateCreated": "2024-01-01",
  "dateModified": new Date().toISOString().split('T')[0]
};

const expertise = [
  {
    label: 'FRONTEND',
    description: t('about.expertise.frontend.desc')
  },
  {
    label: 'BACKEND',
    description: t('about.expertise.backend.desc')
  },
  {
    label: 'DEVOPS',
    description: t('about.expertise.devops.desc')
  }
];
---

<Layout
  title={`${t('about.title')} | ${SITE_TITLE[lang]}`}
  description={t('about.meta.description')}
>
  <main>
    <article class="about-container">
      <span class="page-label">// {t('about.title').toUpperCase()}</span>

      <div class="about-content">
        <div class="about-text">
          <h1 data-scramble={userName.toUpperCase()}>{userName.toUpperCase()}</h1>
          <p class="intro">{t('about.intro')}</p>
        </div>
        <div class="about-image">
          <Image
            src={profilePhoto}
            alt={`Foto de perfil de ${userName}`}
            width={200}
            height={200}
            format="avif"
            quality={80}
          />
        </div>
      </div>

      <section class="about-section" aria-labelledby="background-heading">
        <h2 id="background-heading">{t('about.section.background').toUpperCase()}</h2>
        <p>{t('about.background.p1')}</p>
        <p>{t('about.background.p2')}</p>
      </section>

      <section class="about-section" aria-labelledby="expertise-heading">
        <h2 id="expertise-heading">{t('about.section.expertise').toUpperCase()}</h2>
        <dl class="expertise-list">
          {expertise.map((item) => (
            <div class="expertise-row">
              <dt>{item.label}</dt>
              <dd>{item.description}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="about-section" aria-labelledby="connect-heading">
        <h2 id="connect-heading">{t('about.section.connect').toUpperCase()}</h2>
        <p>
          {t('about.connect.text')}{' '}
          <a href={getRelativeLocaleUrl(lang, 'contact')} class="connect-link">
            {t('about.connect.cta')} <span class="arrow" aria-hidden="true">→</span>
          </a>
        </p>
      </section>
    </article>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(profilePageSchema)} />
</Layout>

<style>
  .about-container {
    max-width: 800px;
    width: 100%;
  }

  .page-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    align-items: start;
    margin-bottom: var(--space-12);
  }

  .about-image img {
    width: 200px;
    height: 200px;
    object-fit: cover;
    border: 2px solid var(--color-accent);
    border-radius: 0;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .intro {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 55ch;
  }

  .about-section {
    margin-bottom: var(--space-12);
  }

  .about-section h2 {
    font-size: 1.125rem;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .about-section p {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: var(--space-4);
    max-width: 65ch;
  }

  .expertise-list {
    display: flex;
    flex-direction: column;
  }

  .expertise-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-6);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .expertise-row:first-child {
    border-top: 1px solid var(--color-border);
  }

  .expertise-row dt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    padding-top: 0.15rem;
  }

  .expertise-row dd {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .connect-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .connect-link:hover {
    color: var(--color-accent-hover);
  }

  .connect-link .arrow {
    display: inline-block;
    transition: transform 0.15s linear;
  }

  .connect-link:hover .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .about-content {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .about-image {
      order: -1;
    }

    .about-image img {
      width: 120px;
      height: 120px;
    }

    .expertise-row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
