---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from "@/const";
import Layout from "./Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { locales } from "@/i18n/ui";
import { getRelativeLocaleUrl } from "astro:i18n";
import { calculateReadingTime } from "@/utils/readingTime";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import FAQSchema from "@/components/FAQSchema.astro";

type Props = {
  entry: CollectionEntry<"blog">;
};

const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, categories, tags, metaDescription, keywords, contentType, lang, faqs } = entry.data;

const currentLang = lang || 'en';
const t = useTranslations(currentLang);

const locale = locales[currentLang];

const dateStr = pubDate.toISOString().slice(0, 10).replace(/-/g, '.');

const readingTime = calculateReadingTime(entry.body);
const wordCount = entry.body ? entry.body.split(/\s+/).filter(word => word.length > 0).length : 0;

const updatedDateStr = updatedDate
  ? updatedDate.toISOString().slice(0, 10).replace(/-/g, '.')
  : null;

const breadcrumbItems = [
  { name: t('nav.home'), url: getRelativeLocaleUrl(currentLang, '/') },
  { name: t('nav.blog'), url: getRelativeLocaleUrl(currentLang, 'blog') },
  { name: title, url: getRelativeLocaleUrl(currentLang, `blog/${entry.slug}`) }
];

const postUrl = new URL(getRelativeLocaleUrl(currentLang, `blog/${entry.slug}`), SITE_URL).toString();
const imageUrl = heroImage ? new URL(heroImage.src, SITE_URL).toString() : null;

const blogPostingSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": metaDescription || description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate || pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Angel Baez",
    "url": SITE_URL,
    "sameAs": [
      "https://github.com/baezor",
      "https://x.com/baezor",
      "https://www.linkedin.com/in/angelromerobaez",
      "https://www.instagram.com/baez0r"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Angel Baez",
    "url": SITE_URL,
    "logo": {
      "@type": "ImageObject",
      "url": new URL("/favicon.png", SITE_URL).toString()
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  },
  "wordCount": wordCount,
  "inLanguage": currentLang === 'es' ? 'es-MX' : 'en-US'
};

if (imageUrl) {
  blogPostingSchema.image = { "@type": "ImageObject", "url": imageUrl };
}
if (keywords && keywords.length > 0) {
  blogPostingSchema.keywords = keywords.join(", ");
}
if (categories && categories.length > 0) {
  blogPostingSchema.articleSection = categories[0];
}
blogPostingSchema.speakable = {
  "@type": "SpeakableSpecification",
  "cssSelector": [".post-title", ".prose p:first-of-type", ".prose h2", ".prose h3"]
};
---

<Layout title={title} description={metaDescription || description} keywords={keywords} image={heroImage} ogType="article">
  <main>
    <article class="blog-post">
      <header class="blog-header">
        <div class="header-layout">
          <div class="header-text">
            <a href={getRelativeLocaleUrl(currentLang, 'blog')} class="back-link">← {t('blog.backToAll').toUpperCase()}</a>

            <h1 class="post-title" data-scramble={title.toUpperCase()}>{title.toUpperCase()}</h1>

            <div class="post-meta">
              <span>{dateStr}</span>
              <span class="meta-sep">//</span>
              <span>{readingTime} {t('blog.readingTime').toUpperCase()}</span>
              {categories && categories.length > 0 && (
                <>
                  <span class="meta-sep">//</span>
                  {categories.map((category, i) => (
                    <>
                      {i > 0 && <span>, </span>}
                      <a href={getRelativeLocaleUrl(currentLang, `category/${category}`)} class="meta-category">{category.toUpperCase()}</a>
                    </>
                  ))}
                </>
              )}
            </div>

            {updatedDateStr && (
              <div class="updated-date">
                {t('blog.updated')} {updatedDateStr}
              </div>
            )}

            {tags && tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag) => (
                  <a href={getRelativeLocaleUrl(currentLang, `tag/${tag}`)} class="tag-badge">#{tag}</a>
                ))}
              </div>
            )}
          </div>

          {
            heroImage && (
              <div class="hero-image-container">
                <Image
                  src={heroImage}
                  alt={title}
                  class="hero-image"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </div>
            )
          }
        </div>
      </header>

      <div class="container">
        <div class="prose">
          <slot />
        </div>

        {faqs && faqs.length > 0 && (
          <section class="faq-section" aria-labelledby="faq-heading">
            <h2 id="faq-heading">{currentLang === 'es' ? 'PREGUNTAS FRECUENTES' : 'FREQUENTLY ASKED QUESTIONS'}</h2>
            <div class="faq-list">
              {faqs.map((faq) => (
                <details class="faq-item">
                  <summary class="faq-question">{faq.question}</summary>
                  <div class="faq-answer">
                    <p>{faq.answer}</p>
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}
      </div>

      <footer class="post-footer container">
        <a href={getRelativeLocaleUrl(currentLang, 'blog')} class="back-link">← {t('blog.backToAll').toUpperCase()}</a>
      </footer>
    </article>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <BreadcrumbSchema items={breadcrumbItems} />
  {faqs && faqs.length > 0 && (
    <FAQSchema faqs={faqs} />
  )}
</Layout>

<style is:global>
  :root {
    --prose-headings: var(--color-text);
    --prose-body: var(--color-text);
    --prose-links: var(--color-accent);
    --prose-links-hover: var(--color-accent-hover);
    --prose-borders: var(--color-border);
    --prose-captions: var(--color-text-muted);
    --prose-code-bg: var(--color-bg-surface);
    --prose-code-text: var(--color-text);
    --prose-pre-bg: #0d0d0d;
    --prose-pre-text: #e8e6e3;
    --prose-blockquote: var(--color-text-muted);
  }

  .light {
    --prose-pre-bg: #1a1a19;
    --prose-pre-text: #F0EFEA;
  }

  .container {
    width: 100%;
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }

  .blog-post {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .blog-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  .header-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-8);
    align-items: end;
  }

  .hero-image-container {
    border: 2px solid var(--color-accent);
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    object-fit: contain;
    border-radius: 0;
    display: block;
  }

  @media (max-width: 768px) {
    .header-layout {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .hero-image-container {
      max-width: 280px;
    }
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: var(--space-6);
  }

  .back-link:hover {
    color: var(--color-accent-hover);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: 0.01em;
    margin-bottom: var(--space-4);
    color: var(--prose-headings);
    text-transform: uppercase;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-3);
  }

  .meta-sep {
    color: var(--color-text-dim);
    user-select: none;
  }

  .meta-category {
    color: var(--color-accent);
    text-decoration: none;
  }

  .meta-category:hover {
    color: var(--color-accent-hover);
  }

  .updated-date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-dim);
    font-style: italic;
    margin-bottom: var(--space-3);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .tag-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: lowercase;
  }

  .tag-badge:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .post-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  /* Prose typography */
  .prose {
    color: var(--prose-body);
    max-width: 65ch;
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin-top: 0;
    margin-bottom: 0.8em;
    line-height: 1.1;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--prose-headings);
  }

  .prose h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-top: 2.5em;
    margin-bottom: 1em;
    line-height: 1.1;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--prose-headings);
    border-bottom: 1px solid var(--prose-borders);
    padding-bottom: var(--space-3);
  }

  .prose h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-top: 1.8em;
    margin-bottom: 0.6em;
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--prose-headings);
  }

  .prose h4 {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    line-height: 1.2;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--prose-headings);
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.625em;
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.625em;
  }

  .prose li {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
    padding-left: 0.375em;
  }

  .prose li::marker {
    color: var(--prose-captions);
  }

  .prose a {
    color: var(--prose-links);
    text-decoration: underline;
    font-weight: 500;
    text-underline-offset: 3px;
  }

  .prose a:hover {
    color: var(--prose-links-hover);
  }

  .prose blockquote {
    font-style: italic;
    color: var(--prose-blockquote);
    border-left: 2px solid var(--color-accent);
    padding: 1rem 1.25rem;
    margin-left: 0;
    margin-right: 0;
    background-color: var(--color-bg-elevated);
  }

  /* Drop cap on first paragraph */
  .prose p:first-of-type::first-letter {
    font-family: var(--font-heading);
    font-size: 3.2em;
    float: left;
    line-height: 0.8;
    margin-right: 0.08em;
    margin-top: 0.05em;
    color: var(--color-accent);
  }

  .prose blockquote p {
    margin-top: 0;
    margin-bottom: 0;
  }

  .prose code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    font-weight: 600;
    color: var(--prose-code-text);
    background-color: var(--prose-code-bg);
    padding: 0.2em 0.4em;
    border-radius: 0;
  }

  .prose pre {
    color: var(--prose-pre-text);
    background-color: var(--prose-pre-bg);
    overflow-x: auto;
    font-weight: 400;
    font-size: 0.85em;
    line-height: 1.7;
    margin-top: 1.7em;
    margin-bottom: 1.7em;
    border-radius: 0;
    border: 1px solid var(--color-border);
    padding: 1.25rem;
  }

  .prose pre code {
    background-color: transparent;
    border-width: 0;
    border-radius: 0;
    padding: 0;
    font-weight: inherit;
    color: inherit;
    font-size: inherit;
    font-family: inherit;
    line-height: inherit;
  }

  .prose table {
    width: 100%;
    table-layout: auto;
    text-align: left;
    margin-top: 2em;
    margin-bottom: 2em;
    font-size: 0.875em;
    line-height: 1.7;
    border-collapse: collapse;
  }

  .prose thead {
    border-bottom: 1px solid var(--prose-borders);
  }

  .prose thead th {
    padding: 0.5em;
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.8em;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--prose-headings);
  }

  .prose tbody tr {
    border-bottom: 1px solid var(--prose-borders);
  }

  .prose tbody tr:last-child {
    border-bottom-width: 0;
  }

  .prose tbody td {
    padding: 0.5em;
    vertical-align: top;
  }

  .prose img {
    margin-top: 2em;
    margin-bottom: 2em;
    border-radius: 0;
  }

  .prose figure {
    margin-top: 2em;
    margin-bottom: 2em;
  }

  .prose figure > * {
    margin-top: 0;
    margin-bottom: 0;
  }

  .prose figcaption {
    color: var(--prose-captions);
    font-size: 0.875em;
    font-family: var(--font-mono);
    line-height: 1.4;
    margin-top: 0.75em;
  }

  .prose hr {
    margin-top: 3em;
    margin-bottom: 3em;
    border: 0;
    border-top: 1px solid var(--prose-borders);
  }

  /* FAQ Section */
  .faq-section {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .faq-section h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: var(--space-6);
    color: var(--prose-headings);
    border-bottom: none;
    padding-bottom: 0;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .faq-question {
    padding: var(--space-4) 0;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--prose-headings);
    font-size: 0.9375rem;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-accent);
  }

  .faq-item[open] .faq-question::after {
    content: '-';
  }

  .faq-answer {
    padding: 0 0 var(--space-4);
    color: var(--prose-body);
  }

  .faq-answer p {
    margin: 0;
    line-height: 1.6;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.75rem;
    }

    .prose {
      font-size: 1rem;
    }

    .prose h2 {
      font-size: 1.25rem;
    }

    .prose h3 {
      font-size: 1.0625rem;
    }
  }
</style>
