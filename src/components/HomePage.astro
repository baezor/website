---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import HeroSection from "@/components/HeroSection.astro";
import BlogPostCard from "@/components/BlogPostCard.astro";
import SectionCTA from "@/components/SectionCTA.astro";
import { useTranslations, type Language } from "@/i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const posts = await getCollection("blog", ({ data }) => data.lang === lang);
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<main id="main-content">
  <div class="homepage">
    <HeroSection lang={lang} />

    <SectionCTA
      heading={t('home.about.heading')}
      text={t('home.about.text')}
      ctaText={t('home.about.cta')}
      ctaHref={getRelativeLocaleUrl(lang, 'about')}
    />

    {recentPosts.length > 0 && (
      <section class="latest-posts" aria-labelledby="posts-heading">
        <span class="section-label">// {t('home.posts.heading').toUpperCase()}</span>
        <h2 id="posts-heading" class="sr-only">{t('home.posts.heading')}</h2>
        <div class="posts-list">
          {recentPosts.map((post) => (
            <BlogPostCard post={post} lang={lang} />
          ))}
        </div>
        <a href={getRelativeLocaleUrl(lang, 'blog')} class="view-all-link">
          {t('home.posts.viewAll')} <span class="arrow" aria-hidden="true">→</span>
        </a>
      </section>
    )}

    <SectionCTA
      heading={t('home.contact.heading')}
      text={t('home.contact.text')}
      ctaText={t('home.contact.cta')}
      ctaHref={getRelativeLocaleUrl(lang, 'contact')}
    />
  </div>
</main>

<style>
  main {
    align-items: stretch;
    justify-content: flex-start;
  }

  .homepage {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--gutter);
  }

  .latest-posts {
    margin-bottom: var(--space-12);
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .view-all-link {
    display: inline-block;
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    text-decoration: none;
  }

  .view-all-link:hover {
    color: var(--color-accent-hover);
  }

  .view-all-link .arrow {
    display: inline-block;
    transition: transform 0.15s linear;
  }

  .view-all-link:hover .arrow {
    transform: translateX(4px);
  }
</style>
