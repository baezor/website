---
import { getLangFromUrl, getLocalizedUrl, useTranslations } from '@/i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const alternateLang = currentLang === 'en' ? 'es' : 'en';
const alternateUrl = getLocalizedUrl(Astro.url.pathname, alternateLang);
const t = useTranslations(currentLang);
---

<div class="language-switcher">
  <span class="lang-current">{currentLang.toUpperCase()}</span>
  <span class="lang-sep">/</span>
  <a
    href={alternateUrl}
    aria-label={alternateLang === 'es' ? t('lang.switch.toSpanish') : t('lang.switch.toEnglish')}
    class="lang-link"
  >
    {alternateLang.toUpperCase()}
  </a>
</div>

<style>
  .language-switcher {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .lang-current {
    color: var(--color-text);
    font-weight: 700;
  }

  .lang-sep {
    color: var(--color-text-dim);
  }

  .lang-link {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lang-link:hover {
    color: var(--color-accent);
  }
</style>
