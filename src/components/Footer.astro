---
import { socialLinks } from "../data/index";
import { SITE_TITLE } from "../const";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const socialTextLinks = socialLinks.map(link => ({
  url: link.url,
  label: link.label,
  text: link.label.toUpperCase().replace(/\s+/g, ''),
}));
---

<footer>
  <div class="footer-container">
    <nav class="social-links" aria-label={t('footer.socialLinks')}>
      {socialTextLinks.map((link, i) => (
        <>
          {i > 0 && <span class="sep">&middot;</span>}
          <a
            href={link.url}
            target={link.url.startsWith("/") ? undefined : "_blank"}
            rel={link.url.startsWith("/") ? undefined : "noopener noreferrer"}
          >
            {link.text}
          </a>
        </>
      ))}
    </nav>

    <div class="footer-meta">
      <span class="footer-mark">&#9632;</span>
      <span>&copy; {new Date().getFullYear()} {SITE_TITLE[lang].toUpperCase()}</span>
      <span class="sep">//</span>
      <span>CANCUN, MX</span>
      <span class="sep">//</span>
      <span>v0.25.0</span>
      <span class="sep">//</span>
      <span>BUILT WITH ASTRO</span>
    </div>

    <div class="footer-utils">
      <LanguageSwitcher />
    </div>
  </div>
</footer>

<style>
  footer {
    padding: var(--space-8) var(--gutter);
    margin-top: auto;
    width: 100%;
    border-top: 2px solid var(--color-accent);
  }

  .footer-mark {
    color: var(--color-accent);
    font-size: 0.5rem;
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .social-links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  .sep {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    user-select: none;
  }

  .footer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
  }

  .footer-utils {
    margin-top: var(--space-2);
  }

  @media (max-width: 640px) {
    .footer-meta {
      font-size: 0.625rem;
    }
  }
</style>
