---
import DarkLightThemeSwitch from "@/components/DarkLightThemeSwitch.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { SITE_TITLE } from "@/const";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { pathname } = Astro.url;
const normalizedPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

const isActive = (path: string) => {
  if (path === "/" || path === "/es") {
    return normalizedPath === path;
  }
  const normalizedTargetPath = path.replace(/\/$/, '');
  return normalizedPath === normalizedTargetPath || normalizedPath.startsWith(normalizedTargetPath + '/');
};

const navItems = [
  { href: getRelativeLocaleUrl(lang, ''), label: t('nav.home'), paths: ["/", "/es"] },
  { href: getRelativeLocaleUrl(lang, 'blog'), label: t('nav.blog'), paths: ["/blog", "/es/blog"] },
  { href: getRelativeLocaleUrl(lang, 'about'), label: t('nav.about'), paths: ["/about", "/es/about"] },
  { href: getRelativeLocaleUrl(lang, 'contact'), label: t('nav.contact'), paths: ["/contact", "/es/contact"] },
];
---

<header>
  <div class="header-container">
    <a href={getRelativeLocaleUrl(lang, '')} class="logo" aria-label={t('nav.aria.home')}>{SITE_TITLE[lang]}</a>

    <nav class="primary-navigation" aria-label="Main navigation">
      <div class="nav-links">
        {navItems.map((item, i) => (
          <>
            {i > 0 && <span class="nav-sep">/</span>}
            <a
              href={item.href}
              class:list={[{ active: item.paths.some(p => isActive(p)) }]}
            >
              {item.paths.some(p => isActive(p)) ? `[ ${item.label} ]` : item.label}
            </a>
          </>
        ))}
      </div>
      <div class="nav-utils">
        <LanguageSwitcher />
        <DarkLightThemeSwitch />
      </div>
    </nav>
  </div>
</header>

<style>
  header {
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-3) var(--gutter);
    gap: var(--space-4);
  }

  .logo {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--color-text);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .primary-navigation {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  .nav-links a.active {
    color: var(--color-text);
  }

  .nav-sep {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    user-select: none;
  }

  .nav-utils {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .header-container {
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .primary-navigation {
      width: 100%;
      justify-content: space-between;
      gap: var(--space-3);
    }

    .nav-links {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      flex-shrink: 1;
      min-width: 0;
    }

    .nav-links::-webkit-scrollbar {
      display: none;
    }

    .nav-utils {
      flex-shrink: 0;
      gap: var(--space-3);
    }
  }
</style>
