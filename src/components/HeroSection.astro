---
import { Image } from "astro:assets";
import { userData, socialLinks } from "@/data/index";
import { useTranslations, type Language } from "@/i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const profilePhoto = userData[0].userPic;
const userName = userData[0].userName;

const socialAbbreviations: Record<string, string> = {
  'LinkedIn': 'LI',
  'GitHub': 'GH',
  'X': 'X',
  'Instagram': 'IG',
  'Facebook': 'FB',
  'Strava': 'STR',
  'RSS Feed': 'RSS',
  'RSS': 'RSS',
};
---

<section class="hero" itemscope itemtype="https://schema.org/Person">
  <div class="hero-content">
    <div class="hero-text">
      <div class="hero-label"><span class="accent-bar"></span>// {t('home.hero.subtitle').toUpperCase()}</div>
      <h1 itemprop="name" data-scramble={userName.toUpperCase()} aria-label={userName}>{userName.toUpperCase()}</h1>
      <p class="tagline" itemprop="description">{t('home.bio')}</p>
      <hr class="hero-rule" />
      <div class="hero-meta">
        <span class="coordinates">21.1619°N, 86.8515°W — CANCUN, MX</span>
        <nav class="social-links" aria-label={t('footer.socialLinks')}>
          {socialLinks.map((link, i) => {
            const isExternal = link.url.startsWith('http://') || link.url.startsWith('https://');
            const abbr = socialAbbreviations[link.label] || link.label.toUpperCase().slice(0, 3);
            return (
              <>
                {i > 0 && <span class="sep">/</span>}
                <a
                  href={link.url}
                  title={link.label}
                  {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  itemprop="sameAs"
                >
                  <span aria-hidden="true">{abbr}</span>
                  <span class="sr-only">{link.label}</span>
                </a>
              </>
            );
          })}
        </nav>
      </div>
    </div>
    <div class="hero-image">
      <Image
        src={profilePhoto}
        alt={`Profile photo of ${userName}`}
        width={180}
        height={180}
        format="avif"
        quality={80}
        loading="eager"
        fetchpriority="high"
        itemprop="image"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    width: 100%;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: start;
  }

  .hero-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
  }

  .accent-bar {
    display: inline-block;
    width: 40px;
    height: 3px;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 6vw, 5rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1;
    margin: 0 0 var(--space-6);
    text-transform: uppercase;
    text-shadow: 2px 2px 0 rgba(255, 59, 48, 0.12);
  }

  .tagline {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 55ch;
    margin: 0 0 var(--space-6);
  }

  .hero-rule {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0 0 var(--space-4);
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Staggered entrance */
  @media (prefers-reduced-motion: no-preference) {
    .hero-label { animation: fadeInUp 0.4s ease both; animation-delay: 0s; }
    h1 { animation: fadeInUp 0.4s ease both; animation-delay: 0.06s; }
    .tagline { animation: fadeInUp 0.4s ease both; animation-delay: 0.12s; }
    .hero-rule { animation: fadeInUp 0.3s ease both; animation-delay: 0.18s; }
    .hero-meta { animation: fadeInUp 0.4s ease both; animation-delay: 0.22s; }
    .hero-image { animation: fadeInUp 0.5s ease both; animation-delay: 0.1s; }
  }

  .coordinates {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .social-links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .social-links .sep {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    user-select: none;
  }

  .hero-image {
    position: relative;
  }

  .hero-image img {
    width: 180px;
    height: 180px;
    object-fit: cover;
    border: 2px solid var(--color-accent);
    border-radius: 0;
    filter: grayscale(100%) contrast(1.1);
    transition: filter 0.3s linear;
  }

  .hero-image:hover img {
    filter: grayscale(0%) contrast(1);
  }

  @media (max-width: 640px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .hero-image {
      order: -1;
    }

    .hero-image img {
      width: 100px;
      height: 100px;
    }

    h1 {
      font-size: clamp(2rem, 10vw, 3rem);
    }
  }
</style>
