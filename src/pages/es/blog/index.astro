---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import BlogPostCard from "@/components/BlogPostCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/const";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = await getCollection("blog", ({ data }) => data.lang === lang);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title={`${t('blog.title')} | ${SITE_TITLE[lang]}`} description={SITE_DESCRIPTION[lang]}>
  <main class="blog-container">
    <span class="page-label">// {t('blog.title').toUpperCase()}</span>
    <h1 data-scramble={t('blog.title').toUpperCase()}>{t('blog.title').toUpperCase()}</h1>
    <span class="entry-count">{sortedPosts.length} ENTRADAS</span>

    <section class="blog-posts">
      {sortedPosts.map((post) => (
        <BlogPostCard post={post} lang={lang} />
      ))}
    </section>
  </main>
</Layout>

<style>
  .blog-container {
    max-width: 860px;
    width: 100%;
  }

  .page-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: var(--space-2);
    letter-spacing: 0.01em;
  }

  .entry-count {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-8);
  }

  .blog-posts {
    display: flex;
    flex-direction: column;
  }
</style>
