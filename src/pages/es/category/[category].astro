---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import BlogPostCard from "@/components/BlogPostCard.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import { SITE_TITLE } from "@/const";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.lang === 'es');

  const categories = new Set<string>();
  posts.forEach((post) => {
    if (post.data.categories) {
      post.data.categories.forEach((category) => categories.add(category));
    }
  });

  return Array.from(categories).map((category) => {
    const categoryPosts = posts
      .filter((post) => post.data.categories?.includes(category))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { category },
      props: { posts: categoryPosts, category },
    };
  });
}

const { posts, category } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const formatCategory = (cat: string) => {
  return cat
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};

const displayCategory = formatCategory(category);
const pageTitle = `${displayCategory} | ${SITE_TITLE[lang]}`;
const description = `Todas las publicaciones en la categoría ${displayCategory}`;

const breadcrumbItems = [
  { name: t('nav.home'), url: getRelativeLocaleUrl(lang, '/') },
  { name: t('nav.blog'), url: getRelativeLocaleUrl(lang, 'blog') },
  { name: displayCategory, url: getRelativeLocaleUrl(lang, `category/${category}`) }
];
---

<Layout title={pageTitle} description={description}>
  <main class="category-archive">
    <a href={getRelativeLocaleUrl(lang, 'blog')} class="back-link">← {t('breadcrumb.blog').toUpperCase()}</a>
    <span class="page-label">// CATEGORÍA</span>
    <h1 data-scramble={displayCategory.toUpperCase()}>{displayCategory.toUpperCase()}</h1>
    <span class="entry-count">{posts.length} {posts.length === 1 ? 'ENTRADA' : 'ENTRADAS'}</span>

    <section class="blog-posts">
      {posts.map((post) => (
        <BlogPostCard post={post} lang={lang} />
      ))}
    </section>
  </main>
  <BreadcrumbSchema items={breadcrumbItems} />
</Layout>

<style>
  .category-archive {
    max-width: var(--max-width);
    width: 100%;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: var(--space-6);
  }

  .back-link:hover {
    color: var(--color-accent-hover);
  }

  .page-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
  }

  .entry-count {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-8);
  }

  .blog-posts {
    display: flex;
    flex-direction: column;
  }
</style>
