---
import Layout from "@/layouts/Layout.astro";
import { SITE_TITLE, SITE_URL } from "@/const";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const redirectUrl = lang === 'es'
  ? `${SITE_URL}/es/contact?success=true`
  : `${SITE_URL}/contact?success=true`;
---

<Layout
  title={`${t('contact.title')} | ${SITE_TITLE[lang]}`}
  description={t('contact.intro')}
>
  <main>
    <div class="contact-container">
      <span class="page-label">// {t('contact.title').toUpperCase()}</span>
      <h1 data-scramble={t('contact.title').toUpperCase()}>{t('contact.title').toUpperCase()}</h1>
      <p class="contact-intro">
        {t('contact.intro')}
      </p>

      <div id="success-message" class="success-message" role="alert" hidden>
        <p>[ {t('contact.form.success').toUpperCase()} ]</p>
      </div>

      <form action="https://formspree.io/f/xkogdgow" method="POST" class="contact-form">
        <input type="hidden" name="_next" value={redirectUrl} />
        <label for="_gotcha" class="honeypot">Don't fill this</label>
        <input type="text" id="_gotcha" name="_gotcha" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="form-group">
          <label for="name">{t('contact.form.name').toUpperCase()}</label>
          <input type="text" id="name" name="name" autocomplete="name" aria-required="true" required />
        </div>

        <div class="form-group">
          <label for="email">{t('contact.form.email').toUpperCase()}</label>
          <input type="email" id="email" name="email" autocomplete="email" aria-required="true" required />
        </div>

        <div class="form-group">
          <label for="subject">{t('contact.form.subject').toUpperCase()}</label>
          <input type="text" id="subject" name="subject" aria-required="true" required />
        </div>

        <div class="form-group">
          <label for="message">{t('contact.form.message').toUpperCase()}</label>
          <textarea id="message" name="message" rows="5" aria-required="true" required></textarea>
        </div>

        <button type="submit" class="submit-btn">{t('contact.form.submit').toUpperCase()}</button>
      </form>

      <div class="contact-note">
        <p>{t('contact.lookingForward')}</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .contact-container {
    max-width: 600px;
    width: 100%;
  }

  .page-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .success-message {
    margin-bottom: var(--space-8);
    padding: var(--space-4);
    border: 1px solid var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    text-align: center;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .contact-intro {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 50ch;
    margin-bottom: var(--space-8);
  }

  .contact-form {
    margin-bottom: var(--space-8);
  }

  .form-group {
    margin-bottom: var(--space-6);
    position: relative;
  }

  .form-group label {
    display: block;
    margin-bottom: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    transition: color 0.15s linear;
  }

  .form-group:focus-within label {
    color: var(--color-accent);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) 0;
    border: none;
    border-bottom: 1px solid var(--color-border);
    font-size: 1rem;
    font-family: var(--font-body);
    background-color: transparent;
    color: var(--color-text);
    border-radius: 0;
    outline: none;
  }

  /* Animated focus underline */
  .form-group:not(:has(textarea))::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .form-group:not(:has(textarea)):focus-within::after {
    transform: scaleX(1);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-bottom-color: transparent;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
    border: 1px solid var(--color-border);
    padding: var(--space-3);
  }

  .form-group textarea:focus {
    border: 2px solid var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
  }

  .submit-btn {
    width: 100%;
    padding: var(--space-4);
    background-color: var(--color-accent);
    color: var(--color-bg);
    border: 2px solid var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    text-transform: uppercase;
  }

  .submit-btn:hover {
    background-color: transparent;
    color: var(--color-accent);
  }

  .submit-btn:active {
    background-color: var(--color-accent-active);
    color: var(--color-bg);
  }

  .contact-note {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    font-style: italic;
  }
</style>

<script>
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('success-message')?.removeAttribute('hidden');
  }
</script>
