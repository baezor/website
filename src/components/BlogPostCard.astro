---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations, type Language } from "@/i18n/utils";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  lang: Language;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);

const dateStr = post.data.pubDate.toISOString().slice(0, 10).replace(/-/g, '.');
const category = post.data.categories?.[0]?.toUpperCase() || '';
const postUrl = getRelativeLocaleUrl(lang, `blog/${post.slug}`);
---

<a href={postUrl} class="post-row">
  <time datetime={post.data.pubDate.toISOString()} class="post-date">{dateStr}</time>
  {category && <span class="post-category">{category}</span>}
  <span class="post-title">{post.data.title}</span>
  <span class="post-arrow" aria-hidden="true">→</span>
</a>

<style>
  .post-row {
    display: grid;
    grid-template-columns: 100px 110px 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-3) var(--space-3);
    border-bottom: 1px solid var(--color-border);
    border-left: 3px solid transparent;
    text-decoration: none;
    color: inherit;
    transition: border-left-color 0.15s linear, background-color 0.15s linear;
  }

  .post-row:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-row:hover {
    background-color: var(--color-bg-elevated);
    border-left-color: var(--color-accent);
  }

  .post-row:hover .post-arrow {
    transform: translateX(4px);
  }

  /* Staggered entrance */
  @media (prefers-reduced-motion: no-preference) {
    .post-row {
      animation: fadeInUp 0.35s ease both;
    }
    .post-row:nth-child(1) { animation-delay: 0.05s; }
    .post-row:nth-child(2) { animation-delay: 0.08s; }
    .post-row:nth-child(3) { animation-delay: 0.11s; }
    .post-row:nth-child(4) { animation-delay: 0.14s; }
    .post-row:nth-child(5) { animation-delay: 0.17s; }
    .post-row:nth-child(6) { animation-delay: 0.20s; }
    .post-row:nth-child(7) { animation-delay: 0.23s; }
    .post-row:nth-child(8) { animation-delay: 0.26s; }
    .post-row:nth-child(9) { animation-delay: 0.29s; }
    .post-row:nth-child(10) { animation-delay: 0.32s; }
    .post-row:nth-child(n+11) { animation-delay: 0.35s; }
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    letter-spacing: 0.03em;
  }

  .post-category {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-arrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    transition: transform 100ms linear;
  }

  @media (max-width: 640px) {
    .post-row {
      grid-template-columns: 1fr auto;
      gap: var(--space-2);
    }

    .post-date {
      grid-column: 1;
      grid-row: 1;
    }

    .post-category {
      grid-column: 2;
      grid-row: 1;
    }

    .post-title {
      grid-column: 1 / -1;
      grid-row: 2;
      white-space: normal;
    }

    .post-arrow {
      display: none;
    }
  }
</style>
